# Credenciales de login de la aplicación
[auth]
username = "admin"
# Generar con: import bcrypt; bcrypt.hashpw(b"tu_clave", bcrypt.gensalt()).decode()
password_hash = "$2b$12$HASH_GENERADO_AQUI"
